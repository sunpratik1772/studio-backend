# --- Required ---
# Postgres connection string (Cloud SQL, Neon, Supabase, etc.)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Google AI Studio API key for Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# --- Optional ---
# Cloud Run sets PORT automatically. Override only for local dev.
PORT=8080

# Pino log level (debug | info | warn | error). Defaults to "info".
LOG_LEVEL=info

# Node runtime mode.
NODE_ENV=production

# NOTE: CORS is currently permissive (any origin) in src/app.ts. To restrict
# it, patch app.ts to read CORS_ORIGIN and pass it to the cors() middleware,
# or front both services with the same origin (recommended). See README.
